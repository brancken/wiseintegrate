{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/sw.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Service-Worker-Allowed": "/"
      },
      "continue": true
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "public, max-age=86400"
      },
      "continue": true
    },
    {
      "src": "/css/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/js/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/images/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
  "src": "/assessment",
  "dest": "/assessment-intro.html"
},
{
  "src": "/assessment/start",
  "dest": "/assessment.html"
},
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/church",
      "dest": "/church/index.html"
    },
    {
      "src": "/business",
      "dest": "/business/index.html"
    },
    {
      "src": "/about",
      "dest": "/about/index.html"
    },
    {
      "src": "/contact",
      "dest": "/contact/index.html"
    },
    {
      "src": "/faq",
      "dest": "/faq/index.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy/index.html"
    },
    {
      "src": "/terms",
      "dest": "/terms/index.html"
    },
    {
      "src": "/blog",
      "dest": "/blog/index.html"
    },
    {
      "src": "/blog/(.*)",
      "dest": "/blog/$1/index.html"
    },
    {
      "src": "/report-summary",
      "dest": "/report-summary/index.html"
    },
    {
      "src": "/report-guide",
      "dest": "/report-guide/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ]
}
